{
  "name": "@alexma03/utcp-code-mode-mcp",
  "version": "1.2.3",
  "description": "Model Context Protocol (MCP) server for UTCP Code Mode - Execute TypeScript code with direct tool access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "utcp-code-mode-mcp": "./bin/utcp-code-mode-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc",
    "prepublishOnly": "pnpm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "utcp",
    "mcp",
    "code-mode",
    "typescript",
    "model-context-protocol",
    "universal-tool-calling-protocol",
    "bridge",
    "tools",
    "ai",
    "code-execution"
  ],
  "author": "Alexma03",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alexma03/alexma03-utcp.git",
    "directory": "packages/code-mode-mcp"
  },
  "homepage": "https://github.com/Alexma03/alexma03-utcp#readme",
  "bugs": {
    "url": "https://github.com/Alexma03/alexma03-utcp/issues"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "5.0.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.20.2",
    "@alexma03/utcp-cli": "^1.1.2",
    "@alexma03/utcp-code-mode": "^1.2.13",
    "@alexma03/utcp-dotenv-loader": "^1.1.2",
    "@alexma03/utcp-file": "^1.1.2",
    "@alexma03/utcp-http": "^1.1.3",
    "@alexma03/utcp-mcp": "^1.1.2",
    "@alexma03/utcp-sdk": "^1.1.1",
    "@alexma03/utcp-text": "^1.1.2",
    "dotenv": "16.0.0",
    "zod": "3.25.76"
  }
}
