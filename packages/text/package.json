{
  "name": "@alexma03/utcp-text",
  "version": "1.1.2",
  "description": "Text content protocol for UTCP - handles direct text content (browser-compatible)",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Alexma03",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alexma03/alexma03-utcp.git",
    "directory": "packages/text"
  },
  "homepage": "https://github.com/Alexma03/alexma03-utcp#readme",
  "bugs": {
    "url": "https://github.com/Alexma03/alexma03-utcp/issues"
  },
  "keywords": [
    "utcp",
    "text",
    "content",
    "browser",
    "tool calling"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@alexma03/utcp-http": "^1.1.3",
    "@alexma03/utcp-sdk": "^1.1.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "typescript": "^5.0.0"
  }
}
